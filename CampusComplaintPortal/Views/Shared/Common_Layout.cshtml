@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Campus Complaint Portal</title>
    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #fff5ef;
            font-family: 'Segoe UI', sans-serif;
        }
        /* Navbar */
        .navbar {
            background: white;
            border-radius: 10px;
            padding: 15px;
        }
        /* Buttons */
        .btn-orange {
            background: #ff6a00;
            color: white;
            border: none;
            padding: 10px 20px;
        }
        .btn-orange:hover {
            background: #e65c00;
            color: white;
        }
        /* Footer */
        .footer {
            margin-top: 40px;
            background: #222;
            color: white;
            padding: 20px;
            text-align: center;
        }
               
        
        /* Top Companies */
        .company-section {
            margin-top: 80px;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="container mt-4">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg">
            <a class="navbar-brand fw-bold text-warning" href="/">Complaint Portal</a>
            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/About">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Contact">Contact</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString()=="TrackComplaint"?"active":"")"
                           href="/Home/TrackComplaint">
                            Track Complaint
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/ReportComplaint">Report Complaint</a>
                    </li>
                </ul>
                @if (Session["UserId"] == null)
                {
                    <div class="ms-3">
                        <a href="/Home/Login" class="btn btn-outline-secondary me-2">
                            Sign In
                        </a>
                        <a href="/Home/JoinNow" class="btn btn-orange">
                            Join Now
                        </a>
                    </div>
                }
                else
                {
                    <div class="ms-3">
                        <span class="me-3 fw-bold text-success">
                            Welcome @Session["UserName"]
                        </span>
                        <a href="/Home/Logout" class="btn btn-danger">
                            Logout
                        </a>
                    </div>
                }
            </div>
        </nav>

        <!-- Page Content -->        
        @RenderBody()

        <!-- Footer -->
        <div class="footer">
            © 2026 Campus Facility Complaint Redressal System
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>