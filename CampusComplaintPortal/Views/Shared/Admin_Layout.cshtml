@{
    if (Session["AdminId"] == null)
    {
        Response.Redirect("~/Admin/Login");
    }

    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Admin_Layout</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f4f6f9;
            font-family: 'Segoe UI';
        }
        /* Sidebar */
        .sidebar {
            width: 220px;
            background: #e8f0fb;
            min-height: 100vh;
            padding: 20px;
            position: fixed;
        }

            .sidebar h5 {
                font-weight: bold;
            }

            .sidebar a {
                display: block;
                padding: 10px;
                margin-bottom: 10px;
                text-decoration: none;
                color: #333;
                border-radius: 8px;
            }

                .sidebar a:hover {
                    background: #d2e3ff;
                }

            .sidebar .active {
                background: #c6dbff;
            }
        /* Main Content */

        .main {
            margin-left: 240px;
            padding: 20px;
        }
        /* Top Bar */
        .topbar {
            background: white;
            padding: 10px 20px;
            border-radius: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        /* Status badges */

        .badge-pending {
            background: #ffc107;
            color: black;
        }

        .badge-progress {
            background: #0d6efd;
        }

        .badge-fixed {
            background: #198754;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <h5>Admin Panel</h5>
        @*<a href="/Admin/Index">Dashboard</a>
            <a class="active" href="/Admin/ManageComplaints">Complaints</a>
            <a href="/Admin/ManageEnquiries">Enquiries</a>
            <a href="/Admin/Notifications">Notifications</a>
            <a href="/Admin/Logout" class="btn btn-danger">Logout</a>*@
        <a class="@(ViewContext.RouteData.Values["action"].ToString() == "Dashboard" ? "active" : "")" href="/Admin/Dashboard">Dashboard</a>

        <a class="@(ViewContext.RouteData.Values["action"].ToString() == "ManageComplaints" ? "active" : "")" href="/Admin/ManageComplaints">Complaints</a>

        <a class="@(ViewContext.RouteData.Values["action"].ToString() == "ManageEnquiries" ? "active" : "")" href="/Admin/ManageEnquiries">Enquiries</a>

        <a class="@(ViewContext.RouteData.Values["action"].ToString() == "Notifications" ? "active" : "")" href="/Admin/Notifications">Notifications</a>
        <a href="/Home" class="btn btn-sm btn-danger mt-3">Logout</a>
    </div>
    <!-- Main Area -->
    <div class="main">
        <!-- Topbar -->
        <div class="topbar">

            <input class="form-control w-25" placeholder="Search">

            <div>
                👤 @Session["AdminName"]
            </div>

        </div>
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
